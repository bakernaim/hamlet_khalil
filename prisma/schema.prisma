// Hamlet Al Khalil — data model
// Bilingual content stored as paired `...Ar` / `...En` fields.
// List fields (highlights) are stored as JSON strings — parse with lib/serialize.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("editor") // "admin" | "editor"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ZiyaratPackage {
  id           String   @id @default(cuid())
  slug         String   @unique
  flag         String
  nameAr       String
  nameEn       String
  durationAr   String
  durationEn   String
  badgeAr      String?
  badgeEn      String?
  highlightsAr String   @default("[]") // JSON string[]
  highlightsEn String   @default("[]") // JSON string[]
  infoAr       String   @default("") // rich-text HTML (sanitized on save)
  infoEn       String   @default("") // rich-text HTML (sanitized on save)
  image        String
  images       String   @default("[]") // JSON string[] of extra gallery image paths (cover is `image`)
  color        String   @default("from-[#1a2444] to-[#0a0f2c]")
  sortOrder    Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TourismPackage {
  id         String   @id @default(cuid())
  slug       String   @unique
  flag       String
  nameAr     String
  nameEn     String
  durationAr String
  durationEn String
  descAr     String
  descEn     String
  infoAr     String   @default("") // rich-text HTML (sanitized on save)
  infoEn     String   @default("") // rich-text HTML (sanitized on save)
  image      String
  images     String   @default("[]") // JSON string[] of extra gallery image paths (cover is `image`)
  sortOrder  Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CurrentTrip {
  id            String    @id @default(cuid())
  titleAr       String
  titleEn       String
  destinationAr String
  destinationEn String
  departureDate DateTime // for recurring trips this is the first departure
  returnDate    DateTime?
  frequency     String    @default("ONCE") // ONCE | WEEKLY | BIWEEKLY | MONTHLY
  recurEndDate  DateTime? // repeating trips generate departures up to this date (inclusive)
  price         Int
  seatsLeft     Int?
  status        String    @default("OPEN") // OPEN | ALMOST_FULL | DEPARTED | CLOSED
  image         String?
  images        String    @default("[]") // JSON string[] of extra gallery image paths (cover is `image`)
  packageType   String? // "ziyarat" | "tourism"
  packageSlug   String? // links to a package card via #anchor
  sortOrder     Int       @default(0)
  published     Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
}

// A booking request submitted from the public site. Reviewed by an admin
// (status starts PENDING); seats are not auto-decremented.
model Booking {
  id            String       @id @default(cuid())
  tripId        String?
  trip          CurrentTrip? @relation(fields: [tripId], references: [id], onDelete: SetNull)
  tripTitleAr   String // snapshot so the record survives trip deletion
  tripTitleEn   String
  departureDate DateTime // the specific departure the customer chose
  fullName      String
  phone         String
  partySize     Int
  roomType      String? // SINGLE | DOUBLE | TRIPLE | QUAD — hotel room preference
  passports     String       @default("[]") // JSON string[] of private passport file tokens
  notes         String?
  status        String       @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// Promo banners rendered between homepage sections (Arbaeen countdown, offers…).
model Banner {
  id          String    @id @default(cuid())
  titleAr     String
  titleEn     String
  badgeAr     String? // small uppercase chip above the title
  badgeEn     String?
  textAr      String
  textEn      String
  image       String? // background photo (uploaded)
  theme       String    @default("green") // "green" | "amber"
  displayMode String    @default("bar") // "bar" (thin bottom bar) | "modal" (popup on page load) | "both"
  targetDate  DateTime? // when set and in the future, shows a live countdown
  priceFrom   Int? // when set, shows a "From $X" box
  noteAr      String? // extra line next to the price, e.g. "١٤ يوماً"
  noteEn      String?
  ctaAr       String? // CTA label; defaults to "تواصل معنا" / "Contact Us"
  ctaEn       String?
  sortOrder   Int       @default(0)
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Visitor-submitted reviews. Hidden until an admin approves them.
model Review {
  id        String   @id @default(cuid())
  name      String
  tripLabel String? // optional free-text "which trip was this about"
  rating    Int // 1–5 stars
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-uploaded gallery media (trip photos & short videos) shown on the site.
model GalleryItem {
  id        String   @id @default(cuid())
  type      String // "image" | "video"
  src       String // /api/media/… upload path
  captionAr String?
  captionEn String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-managed Instagram posts shown in the homepage feed grid.
model InstagramPost {
  id        String   @id @default(cuid())
  image     String // /api/media/… upload path
  permalink String   @default("") // link to the post on Instagram (optional)
  captionAr String?
  captionEn String?
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-uploaded photos cycled as the homepage hero background.
model HeroImage {
  id        String   @id @default(cuid())
  src       String // /api/media/… upload path
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A hotel we can help a customer book, in Iran/Iraq (or elsewhere). Managed in
// the admin "Hotels" section — separate from trip packages/bookings.
model Hotel {
  id          String                @id @default(cuid())
  countryAr   String
  countryEn   String
  cityAr      String
  cityEn      String
  nameAr      String
  nameEn      String
  addressAr   String?
  addressEn   String?
  image       String? // /api/media/… upload path, optional
  roomTypesAr String                @default("[]") // JSON string[] — room types this hotel offers
  roomTypesEn String                @default("[]")
  images      String                @default("[]") // JSON string[] of extra gallery image paths (cover is `image`)
  priceStart  Int? // starting price in USD (shows "From $X"), optional
  mealBreakfast Boolean             @default(false)
  mealLunch     Boolean             @default(false)
  mealDinner    Boolean             @default(false)
  website     String? // link to the hotel's website, if any
  sortOrder   Int                   @default(0)
  published   Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  requests    HotelBookingRequest[]
}

// A hotel-booking request submitted from the public site. Kept separate from
// the trip Booking model — no departures/passports/payment step, just enough
// to let staff follow up over WhatsApp.
model HotelBookingRequest {
  id          String   @id @default(cuid())
  hotelId     String?
  hotel       Hotel?   @relation(fields: [hotelId], references: [id], onDelete: SetNull)
  hotelNameAr String // snapshot so the record survives hotel deletion
  hotelNameEn String
  fullName    String
  phone       String
  rooms       String   @default("[]") // JSON string[] of room types, one entry per room
  meals       String   @default("[]") // JSON string[] of requested meals: BREAKFAST | LUNCH | DINNER
  checkIn     DateTime? // requested check-in date
  nights      Int? // number of nights, optional
  status      String   @default("PENDING") // PENDING | CONTACTED | CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A flight / plane ticket offering managed in the admin and shown on the site.
model Flight {
  id           String                 @id @default(cuid())
  fromAr       String
  fromEn       String
  toAr         String
  toEn         String
  airlineAr    String
  airlineEn    String
  mealIncluded Boolean                @default(false) // is a meal served on board
  price        Int // ticket price in USD
  image        String? // optional airline logo / photo (/api/media/…)
  sortOrder    Int                    @default(0)
  published    Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  requests     FlightBookingRequest[]
}

// A flight-booking request submitted from the public site. Like the hotel
// request: no payment step — just enough to follow up over WhatsApp.
model FlightBookingRequest {
  id         String   @id @default(cuid())
  flightId   String?
  flight     Flight?  @relation(fields: [flightId], references: [id], onDelete: SetNull)
  fromAr     String // snapshots so the record survives flight deletion
  fromEn     String
  toAr       String
  toEn       String
  airlineAr  String
  airlineEn  String
  fullName   String
  phone      String
  travelDate DateTime // the date the traveler wants to fly
  passengers Int      @default(1)
  passports  String   @default("[]") // JSON string[] of private passport file tokens, one per passenger
  status     String   @default("PENDING") // PENDING | CONTACTED | CLOSED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}
